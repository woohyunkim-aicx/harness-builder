{
  "_comment": "Lifecycle hooks. Generated by harness-builder.",
  "hooks": {
    "Stop": [
      {
        "_comment_": "TypeScript check — remove if not a TypeScript project",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/tsc-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_comment_": "Database protection — remove if no database",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/db-protection.sh \"$TOOL_INPUT\""
          }
        ],
        "description": "Block destructive database operations"
      }
    ]
  }
}
